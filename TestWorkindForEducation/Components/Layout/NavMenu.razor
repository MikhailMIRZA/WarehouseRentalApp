@* NavMenu.razor *@

<div class="nav-menu">
    <h3 class="px-4 py-3">🏭 СкладСтрой</h3>

    <div class="nav-links">
        <div class="nav-item">
            <a href="/" class="nav-link">🏠 Главная</a>
        </div>
        <div class="nav-item">
            <a href="/storage.html" class="nav-link">📦 Помещения</a>
        </div>
        <div class="nav-item">
            <a href="/profile.html" class="nav-link">👤 Профиль</a>
        </div>
        <div class="nav-item">
            <a href="/admin.html" class="nav-link" id="adminLink" style="display: none;">⚙️ Админка</a>
        </div>
    </div>

    <div class="user-section" id="userSection">
        <div id="userProfileInfo">
            <p class="text-muted mb-2">Для аренды помещения</p>
            <button class="btn-login" onclick="showLoginModal()">Войти</button>
        </div>
    </div>
</div>

<style>
    .nav-menu {
        width: 250px;
        background: #2c3e50;
        color: white;
        height: 100vh;
        position: fixed;
        left: 0;
        top: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
    }

        .nav-menu h3 {
            margin: 0;
            padding: 20px;
            font-size: 1.5rem;
            background: rgba(0,0,0,0.2);
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

    .nav-links {
        display: flex;
        flex-direction: column;
        gap: 5px;
        padding: 15px;
        flex: 1;
    }

    .nav-item {
        padding: 5px 0;
    }

    .nav-link {
        display: block;
        padding: 12px 15px;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        transition: all 0.3s;
        font-weight: 500;
    }

        .nav-link:hover {
            background-color: #34495e;
            transform: translateX(5px);
        }

        .nav-link.active {
            background-color: #3498db;
            box-shadow: 0 4px 12px rgba(52, 152, 219, 0.3);
        }

    .user-section {
        padding: 20px;
        border-top: 1px solid rgba(255,255,255,0.1);
        background: rgba(0,0,0,0.15);
    }

    .user-info {
        background: rgba(255,255,255,0.1);
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 10px;
    }

    .user-name {
        font-weight: 600;
        margin-bottom: 5px;
    }

    .user-role {
        font-size: 0.85rem;
        opacity: 0.8;
    }

    .btn-login {
        width: 100%;
        padding: 10px;
        background: #3498db;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 500;
        transition: background 0.3s;
    }

        .btn-login:hover {
            background: #2980b9;
        }

    .btn-logout {
        width: 100%;
        padding: 10px;
        background: rgba(231, 76, 60, 0.2);
        color: #e74c3c;
        border: 1px solid rgba(231, 76, 60, 0.3);
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.3s;
        font-weight: 500;
    }

        .btn-logout:hover {
            background: rgba(231, 76, 60, 0.3);
        }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        updateNavMenu();
    });

    function updateNavMenu() {
        const userId = localStorage.getItem('storage_user_id');
        const userRole = localStorage.getItem('storage_user_role');
        const userName = localStorage.getItem('storage_user_name') || 'Гость';

        const userSection = document.getElementById('userProfileInfo');
        const adminLink = document.getElementById('adminLink');

        const currentPage = window.location.pathname.split('/').pop();
        document.querySelectorAll('.nav-link').forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('href')?.includes(currentPage)) {
                link.classList.add('active');
            }
        });

        if (userId) {
            if (userRole === 'admin') {
                adminLink.style.display = 'block';
                userSection.innerHTML = `
                    <div class="user-info">
                        <div class="user-name">${userName}</div>
                        <div class="user-role">Администратор</div>
                    </div>
                    <button class="btn-logout" onclick="logout()">Выйти</button>
                `;
            } else {
                adminLink.style.display = 'none';
                userSection.innerHTML = `
                    <div class="user-info">
                        <div class="user-name">${userName}</div>
                        <div class="user-role">Пользователь</div>
                    </div>
                    <button class="btn-logout" onclick="logout()">Выйти</button>
                `;
            }
        } else {
            adminLink.style.display = 'none';
            userSection.innerHTML = `
                <p class="text-muted mb-2">Для аренды помещения</p>
                <button class="btn-login" onclick="showLoginModal()">Войти</button>
            `;
        }
    }

    function logout() {
        if (confirm('Вы уверены, что хотите выйти?')) {
            localStorage.removeItem('storage_user_id');
            localStorage.removeItem('storage_user_name');
            localStorage.removeItem('storage_user_email');
            localStorage.removeItem('storage_user_role');
            localStorage.removeItem('storage_user_created');
            location.reload();
        }
    }

    function showLoginModal() {
        if (window.location.pathname.includes('storage.html')) {
            if (typeof window.openBookingModal === 'function') {
                window.openBookingModal(null);
            } else {
                window.location.href = '/storage.html';
            }
        } else {
            window.location.href = '/storage.html';
        }
    }
</script>

